# Cloudflare Pages headers
# Docs: https://developers.cloudflare.com/pages/configuration/headers/

# Long-lived caching for fingerprinted Astro assets and anything under /assets/.
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Pagefind index — fingerprinted by content; safe to cache aggressively.
/pagefind/*
  Cache-Control: public, max-age=31536000, immutable

# Default for everything else (HTML, sitemap, redirects targets) — short TTL.
/*
  Cache-Control: public, max-age=3600
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
