---
import { getStrings } from '../i18n';
import type { Lang } from '../i18n';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = getStrings(lang);
---

{/*
  Progressive enhancement: renders as a link to the search page so it works
  without JS. With JS, the click is intercepted by SearchModal and opens
  the modal instead.
*/}
<a
  href={`/${lang}/search`}
  data-search-trigger
  aria-label={t.search.open}
  title={t.search.open}
  class="inline-flex h-9 w-9 items-center justify-center text-[color:var(--color-ink-muted)] hover:text-[color:var(--color-ink)] transition-colors"
>
  <svg
    aria-hidden="true"
    viewBox="0 0 20 20"
    fill="none"
    stroke="currentColor"
    stroke-width="1.6"
    stroke-linecap="round"
    stroke-linejoin="round"
    class="h-5 w-5"
  >
    <circle cx="9" cy="9" r="6" />
    <path d="m17 17-3.5-3.5" />
  </svg>
</a>
