---
// Hand-crafted landmark silhouettes for catalogue cards.
// Each is a minimal single-path outline designed for 60px tall display.
// Style: fill:currentColor — the surrounding CSS controls opacity + colour.
//
// Substitutions (per Phase 6 spec):
//   kyrgyzstan: Tian Shan mountain peaks silhouette (Manas portrait too complex
//     to render as a clean line silhouette at this size).
interface Props {
  slug: string;
  class?: string;
}
const { slug, class: className } = Astro.props;
---

{slug === 'germany' && (
  <svg viewBox="0 0 80 60" class={className} aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
    {/* Brandenburg Gate — columned portico with quadriga silhouette */}
    <rect x="5" y="15" width="70" height="4" />
    <rect x="8" y="19" width="3" height="38" />
    <rect x="20" y="19" width="3" height="38" />
    <rect x="32" y="19" width="3" height="38" />
    <rect x="45" y="19" width="3" height="38" />
    <rect x="57" y="19" width="3" height="38" />
    <rect x="69" y="19" width="3" height="38" />
    <rect x="3" y="55" width="74" height="3" />
    <path d="M30 15 L30 6 L50 6 L50 15 Z" />
  </svg>
)}

{slug === 'usa' && (
  <svg viewBox="0 0 60 60" class={className} aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
    {/* Statue of Liberty — torch + crown profile */}
    <rect x="25" y="42" width="10" height="14" />
    <rect x="20" y="56" width="20" height="3" />
    <circle cx="30" cy="30" r="6" />
    {/* Crown spikes */}
    <path d="M30 18 L28 23 L26 18 L24 23 L22 18 L20 23 L30 24 Z" />
    <path d="M30 18 L32 23 L34 18 L36 23 L38 18 L40 23 L30 24 Z" />
    {/* Torch arm + flame */}
    <rect x="29" y="6" width="3" height="20" transform="rotate(-15 30 16)" />
    <path d="M30 4 Q27 1 30 0 Q33 1 30 4 Z" transform="translate(8 -1)" />
  </svg>
)}

{slug === 'uk' && (
  <svg viewBox="0 0 30 60" class={className} aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
    {/* Big Ben — clock tower */}
    <rect x="10" y="30" width="10" height="28" />
    <rect x="11" y="16" width="8" height="14" />
    <circle cx="15" cy="22" r="3" fill="var(--color-beige)" />
    <rect x="8" y="14" width="14" height="2" />
    <rect x="12" y="6" width="6" height="8" />
    <path d="M12 6 L15 0 L18 6 Z" />
  </svg>
)}

{slug === 'turkey' && (
  <svg viewBox="0 0 80 60" class={className} aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
    {/* Hagia Sophia — central dome + 2 minarets */}
    <rect x="20" y="40" width="40" height="18" />
    <path d="M20 40 Q40 14 60 40 Z" />
    <rect x="5" y="22" width="3" height="36" />
    <path d="M3.5 22 L6.5 22 L6.5 18 L5 12 L3.5 18 Z" />
    <rect x="72" y="22" width="3" height="36" />
    <path d="M70.5 22 L73.5 22 L73.5 18 L72 12 L70.5 18 Z" />
    <circle cx="40" cy="32" r="2" fill="var(--color-beige)" />
  </svg>
)}

{slug === 'uae' && (
  <svg viewBox="0 0 30 60" class={className} aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
    {/* Burj Khalifa — tapered spire */}
    <path d="M13 58 L17 58 L18 38 L19 22 L17 10 L15 4 L13 10 L11 22 L12 38 Z" />
    <path d="M15 4 L15 0" stroke="currentColor" stroke-width="0.8" fill="none" />
  </svg>
)}

{slug === 'china' && (
  <svg viewBox="0 0 60 60" class={className} aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
    {/* Pagoda — tiered roof structure */}
    <rect x="22" y="52" width="16" height="6" />
    <path d="M16 46 L44 46 L40 52 L20 52 Z" />
    <rect x="24" y="40" width="12" height="6" />
    <path d="M18 36 L42 36 L38 40 L22 40 Z" />
    <rect x="25" y="30" width="10" height="6" />
    <path d="M19 26 L41 26 L37 30 L23 30 Z" />
    <rect x="26" y="20" width="8" height="6" />
    <path d="M20 16 L40 16 L36 20 L24 20 Z" />
    <rect x="29" y="8" width="2" height="8" />
    <circle cx="30" cy="5" r="3" />
  </svg>
)}

{slug === 'south-korea' && (
  <svg viewBox="0 0 80 60" class={className} aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
    {/* Gyeongbokgung Gate — curved upturned roof */}
    <rect x="10" y="42" width="60" height="16" />
    {/* Lower roof */}
    <path d="M2 38 Q10 30 22 30 L58 30 Q70 30 78 38 Q72 36 60 36 L20 36 Q8 36 2 38 Z" />
    {/* Upper roof */}
    <path d="M14 24 Q22 18 32 18 L48 18 Q58 18 66 24 Q58 22 50 22 L30 22 Q22 22 14 24 Z" />
    <rect x="15" y="34" width="3" height="8" fill="var(--color-beige)" />
    <rect x="62" y="34" width="3" height="8" fill="var(--color-beige)" />
  </svg>
)}

{slug === 'singapore' && (
  <svg viewBox="0 0 80 60" class={className} aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
    {/* Marina Bay Sands — three towers with sky deck */}
    <rect x="8" y="22" width="14" height="36" />
    <rect x="33" y="22" width="14" height="36" />
    <rect x="58" y="22" width="14" height="36" />
    {/* Sky deck */}
    <path d="M4 16 L76 16 L72 22 L8 22 Z" />
  </svg>
)}

{slug === 'malaysia' && (
  <svg viewBox="0 0 40 60" class={className} aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
    {/* Petronas Twin Towers */}
    {/* Left tower */}
    <rect x="6" y="14" width="10" height="44" />
    <rect x="7" y="8" width="8" height="6" />
    <rect x="10" y="2" width="2" height="6" />
    {/* Right tower */}
    <rect x="24" y="14" width="10" height="44" />
    <rect x="25" y="8" width="8" height="6" />
    <rect x="28" y="2" width="2" height="6" />
    {/* Skybridge */}
    <rect x="16" y="30" width="8" height="2" />
    <rect x="16" y="34" width="8" height="2" />
  </svg>
)}

{slug === 'canada' && (
  <svg viewBox="0 0 30 60" class={className} aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
    {/* CN Tower — pod on spire */}
    <rect x="14" y="58" width="2" height="0" />
    <path d="M13 58 L17 58 L16 36 L17 22 L13 22 L14 36 Z" />
    {/* Observation pod */}
    <ellipse cx="15" cy="18" rx="6" ry="2.5" />
    <path d="M11 18 L19 18 L18 14 L12 14 Z" />
    {/* Antenna */}
    <rect x="14.4" y="2" width="1.2" height="12" />
  </svg>
)}

{slug === 'czech-republic' && (
  <svg viewBox="0 0 60 60" class={className} aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
    {/* Prague Astronomical Clock face */}
    <circle cx="30" cy="30" r="22" fill="none" stroke="currentColor" stroke-width="2" />
    <circle cx="30" cy="30" r="14" fill="none" stroke="currentColor" stroke-width="1" />
    {/* Clock hands */}
    <line x1="30" y1="30" x2="30" y2="14" stroke="currentColor" stroke-width="1.5" />
    <line x1="30" y1="30" x2="42" y2="30" stroke="currentColor" stroke-width="1.5" />
    {/* Hour markers */}
    <circle cx="30" cy="10" r="1.2" />
    <circle cx="30" cy="50" r="1.2" />
    <circle cx="10" cy="30" r="1.2" />
    <circle cx="50" cy="30" r="1.2" />
    <circle cx="30" cy="30" r="1.8" />
  </svg>
)}

{slug === 'uzbekistan' && (
  <svg viewBox="0 0 60 60" class={className} aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
    {/* Registan portal — arched gateway with flanking towers */}
    <rect x="0" y="50" width="60" height="8" />
    {/* Main facade */}
    <rect x="6" y="14" width="48" height="44" />
    {/* Pointed arch (cut out via beige) */}
    <path d="M20 58 L20 36 Q20 22 30 22 Q40 22 40 36 L40 58 Z" fill="var(--color-beige)" />
    {/* Two flanking minarets */}
    <rect x="2" y="10" width="4" height="48" />
    <rect x="54" y="10" width="4" height="48" />
    <path d="M2 10 L6 10 L4 4 Z" />
    <path d="M54 10 L58 10 L56 4 Z" />
  </svg>
)}

{slug === 'kazakhstan' && (
  <svg viewBox="0 0 40 60" class={className} aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
    {/* Bayterek Tower — sphere on tapered legs */}
    <circle cx="20" cy="18" r="9" />
    {/* Tapered tripod legs */}
    <path d="M18 25 L14 58 L16 58 L20 27 Z" />
    <path d="M22 25 L26 58 L24 58 L20 27 Z" />
    <path d="M19 22 L20 58 L20 22 Z" />
    {/* Base */}
    <rect x="10" y="56" width="20" height="3" />
    {/* Top spike */}
    <rect x="19.4" y="2" width="1.2" height="8" />
  </svg>
)}

{slug === 'kyrgyzstan' && (
  <svg viewBox="0 0 80 60" class={className} aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
    {/* Tian Shan mountain peaks silhouette (substituted for Manas: peaks read
        more cleanly at small sizes than a portrait) */}
    <path d="M0 58 L0 38 L12 28 L20 36 L32 18 L44 32 L54 22 L66 36 L76 28 L80 38 L80 58 Z" />
    {/* Snow caps */}
    <path d="M30 22 L32 18 L34 22 Z" fill="var(--color-beige)" />
    <path d="M52 24 L54 22 L56 24 Z" fill="var(--color-beige)" />
  </svg>
)}
