---
import { Image } from 'astro:assets';
import Layout from '../../layouts/Layout.astro';
import { getStrings, LANGS } from '../../i18n';
import type { Lang } from '../../i18n';
import landingHero from '../../assets/landing/hero.jpg';
import landingCredits from '../../assets/landing/credits.json';

export function getStaticPaths() {
  return LANGS.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
const t = getStrings(lang);
const headlineLines = t.landing.headline.split('\n');
// Split each line into words to enable word-by-word stagger.
const headlineWords: string[][] = headlineLines.map((line) =>
  line.split(' ').filter((w) => w.length > 0),
);
let wordIndex = 0;
---

<Layout lang={lang} title={t.siteName} description={t.tagline}>
  {/* Hero — magazine-style two-column on desktop, stacked on mobile.
      Left column (~50%): eyebrow → headline (word-stagger) → subtitle → CTA.
      Right column (~40%): editorial photograph. */}
  <section class="page-container py-20 md:py-28 lg:py-32">
    <div class="grid grid-cols-1 gap-10 lg:grid-cols-[1fr_40%] lg:gap-[5%] items-center">
      <div class="landing-text-column">
        <h1
          class="landing-headline text-balance text-left"
          style="font-family: var(--font-display); font-size: clamp(2.5rem, 7.5vw, 5.25rem); font-weight: 600; line-height: 1.04; letter-spacing: -0.02em;"
        >
          {headlineWords.map((words, lineIdx) => (
            <Fragment>
              {lineIdx > 0 && <br />}
              {words.map((word) => {
                const i = wordIndex++;
                return (
                  <Fragment>
                    <span
                      class="landing-word"
                      style={`--word-delay: ${i * 80}ms;`}
                    >{word}</span>
                    {' '}
                  </Fragment>
                );
              })}
            </Fragment>
          ))}
        </h1>

        <p class="landing-subtitle">{t.landing.subtitle}</p>

        <div class="landing-cta-wrap">
          <a
            href={`/${lang}/apply`}
            class="cta-pill landing-cta group inline-flex items-center justify-center rounded-full bg-[color:var(--color-red-soft)] pl-14 pr-12 py-4 text-base font-medium text-[color:var(--color-beige)] transition-colors hover:bg-[color:var(--color-red)] focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-[color:var(--color-ink)]"
            style="gap: 12px;"
          >
            <span>{t.landing.cta}</span>
            <svg
              aria-hidden="true"
              viewBox="0 0 24 24"
              width="20"
              height="20"
              fill="none"
              stroke="#1A1A1A"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="cta-pill-arrow"
            >
              <path d="M5 12h14" />
              <path d="m13 6 6 6-6 6" />
            </svg>
          </a>
        </div>
      </div>

      <figure class="landing-figure">
        <div class="landing-figure-frame">
          <Image
            src={landingHero}
            alt=""
            widths={[480, 720, 960, 1280]}
            sizes="(min-width: 1024px) 40vw, 100vw"
            format="webp"
            quality={75}
            class="landing-figure-img"
            loading="eager"
            fetchpriority="high"
          />
        </div>
        <figcaption class="landing-figure-caption">
          <a
            href={landingCredits.hero.url}
            target="_blank"
            rel="noopener noreferrer"
            class="hover:text-[color:var(--color-red)] transition-colors"
          >Photo: {landingCredits.hero.photographer} / Unsplash</a>
        </figcaption>
      </figure>
    </div>
  </section>

  {/* What is Unisomnia — narrow editorial column */}
  <section class="page-container border-t border-[color:var(--color-rule)] py-24 md:py-28">
    <div class="mx-auto max-w-2xl">
      <span aria-hidden="true" class="block w-[60px] h-[1.5px] bg-[color:var(--color-red)] mb-5"></span>
      <p
        class="mb-3"
        style="font-family: var(--font-display); font-size: 0.8125rem; text-transform: uppercase; letter-spacing: 0.18em; color: var(--color-red); font-weight: 500;"
      >
        {t.landing.whatEyebrow}
      </p>
      <h2 class="mb-8" style="font-size: clamp(1.75rem, 3.5vw, 2.25rem);">
        {t.landing.whatTitle}
      </h2>
      <p class="mb-5 text-lg leading-relaxed text-balance">{t.landing.what1}</p>
      <p class="text-lg leading-relaxed text-[color:var(--color-ink-muted)] text-balance">{t.landing.what2}</p>
    </div>
  </section>

  {/* 3-feature row */}
  <section class="page-container border-t border-[color:var(--color-rule)] py-24 md:py-28">
    <div class="mx-auto max-w-4xl">
      <div class="text-center mb-16">
        <span aria-hidden="true" class="inline-block w-[60px] h-[1.5px] bg-[color:var(--color-red)] mb-4"></span>
        <p
          style="font-family: var(--font-display); font-size: 0.8125rem; text-transform: uppercase; letter-spacing: 0.18em; color: var(--color-red); font-weight: 500;"
        >
          {t.landing.featuresEyebrow}
        </p>
      </div>

      <ul class="grid grid-cols-1 gap-12 md:grid-cols-3 md:gap-10">
        {[
          { icon: 'catalog', title: t.landing.f1Title, desc: t.landing.f1Desc },
          { icon: 'steps', title: t.landing.f2Title, desc: t.landing.f2Desc },
          { icon: 'cost', title: t.landing.f3Title, desc: t.landing.f3Desc },
        ].map((f) => (
          <li class="flex flex-col items-center text-center">
            <svg
              aria-hidden="true"
              viewBox="0 0 32 32"
              class="mb-5 h-9 w-9 text-[color:var(--color-ink)]"
              fill="none"
              stroke="currentColor"
              stroke-width="1.4"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              {f.icon === 'catalog' && <Fragment>
                <rect x="5" y="6" width="9" height="20" />
                <rect x="18" y="6" width="9" height="20" />
              </Fragment>}
              {f.icon === 'steps' && <Fragment>
                <path d="M6 24h6v-6" />
                <path d="M14 18h6v-6" />
                <path d="M22 12h6V6" />
              </Fragment>}
              {f.icon === 'cost' && <Fragment>
                <path d="M16 4v24" />
                <path d="M22 10h-9a3 3 0 0 0 0 6h6a3 3 0 0 1 0 6h-9" />
              </Fragment>}
            </svg>
            <h3 class="mb-2 text-xl">{f.title}</h3>
            <p class="text-[color:var(--color-ink-muted)] max-w-[28ch]">{f.desc}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>
</Layout>
