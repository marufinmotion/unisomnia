---
import Layout from '../../../layouts/Layout.astro';
import CountrySilhouette from '../../../components/CountrySilhouette.astro';
import { getStrings, LANGS, COUNTRY_ISO } from '../../../i18n';
import type { Lang } from '../../../i18n';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  return LANGS.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
const t = getStrings(lang);

const all = await getCollection('countries');
const countries = all
  .filter((entry) => entry.id.startsWith(`${lang}/`))
  .map((entry) => ({
    slug: entry.data.slug,
    name: entry.data.name,
    iso: COUNTRY_ISO[entry.data.slug] ?? 'xx',
    tag: entry.data.tag ?? '',
    order: entry.data.order,
  }))
  .sort((a, b) => a.order - b.order);
---

<Layout lang={lang} title={t.apply.heading}>
  <section class="page-container py-16 md:py-24">
    <header class="mb-14 max-w-2xl">
      <span aria-hidden="true" class="block w-[60px] h-[1.5px] bg-[color:var(--color-red)] mb-5"></span>
      <p
        class="mb-3"
        style="font-family: var(--font-display); font-size: 0.8125rem; text-transform: uppercase; letter-spacing: 0.18em; color: var(--color-red); font-weight: 500;"
      >
        {t.apply.eyebrow}
      </p>
      <h1
        class="mb-5"
        style="font-family: var(--font-display); font-size: clamp(2.5rem, 6vw, 4rem); font-weight: 600; line-height: 1.04; letter-spacing: -0.02em;"
      >
        {t.apply.heading}
      </h1>
      <p class="text-lg text-[color:var(--color-ink-muted)] text-balance">{t.apply.sub}</p>
    </header>

    <div class="mb-14 border-t border-[color:var(--color-rule)] pt-8">
      <label class="block">
        <span class="sr-only">{t.apply.filterPlaceholder}</span>
        <input
          type="search"
          id="country-filter"
          placeholder={t.apply.filterPlaceholder}
          autocomplete="off"
          class="w-full max-w-md border-0 border-b border-[color:var(--color-rule)] bg-transparent px-1 py-3 text-base text-[color:var(--color-ink)] placeholder:text-[color:var(--color-ink-muted)] focus:border-[color:var(--color-red)] focus:outline-none focus:ring-0 transition-colors"
        />
      </label>
    </div>

    <ul id="country-grid" class="grid grid-cols-1 gap-x-10 gap-y-12 sm:grid-cols-2 lg:grid-cols-3">
      {countries.map((c, i) => (
        <li data-country-name={c.name.toLowerCase()}>
          <a
            href={`/${lang}/apply/${c.slug}`}
            class="country-card group relative block border-t border-[color:var(--color-rule)] pt-6 cursor-pointer overflow-hidden"
            aria-label={c.name}
          >
            <CountrySilhouette slug={c.slug} class="country-card-silhouette" />
            <div class="relative z-10">
              <div class="mb-6 flex items-center justify-between">
                <span class={`fi fi-${c.iso} country-card-flag`} aria-hidden="true"></span>
                <span
                  class="text-[color:var(--color-ink-muted)]"
                  style="font-family: var(--font-display); font-size: 0.75rem; letter-spacing: 0.18em; text-transform: uppercase;"
                >{String(i + 1).padStart(2, '0')}</span>
              </div>
              <h2
                class="mb-2 group-hover:[text-decoration:underline] group-hover:[text-decoration-color:var(--color-red)] group-hover:[text-decoration-thickness:1.5px] group-hover:underline-offset-[6px]"
                style="font-family: var(--font-display); font-size: 1.625rem; font-weight: 600; letter-spacing: -0.01em;"
              >
                {c.name}
              </h2>
              {c.tag && <p class="text-sm text-[color:var(--color-ink-muted)]">{c.tag}</p>}
            </div>
          </a>
        </li>
      ))}
    </ul>

    <p id="country-empty" hidden class="mt-16 text-center text-[color:var(--color-ink-muted)]">
      {t.apply.empty}
    </p>
  </section>

  <script is:inline>
    (function () {
      const input = document.getElementById('country-filter');
      const grid = document.getElementById('country-grid');
      const empty = document.getElementById('country-empty');
      if (!input || !grid || !empty) return;
      const items = Array.from(grid.querySelectorAll('[data-country-name]'));
      input.addEventListener('input', () => {
        const q = input.value.trim().toLowerCase();
        let shown = 0;
        for (const li of items) {
          const name = li.getAttribute('data-country-name') || '';
          const match = name.includes(q);
          li.hidden = !match;
          if (match) shown++;
        }
        empty.hidden = shown !== 0;
      });
    })();

    // Stagger entrance: first visit only (sessionStorage flag).
    // Per spec: 30ms inter-card delay, 250ms transition, total ~670ms.
    // Skipped entirely under prefers-reduced-motion.
    (function () {
      const grid = document.getElementById('country-grid');
      if (!grid) return;
      const prefersReduced =
        window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (prefersReduced) return;

      let seen = false;
      try { seen = sessionStorage.getItem('unisomnia.catalog.seen') === '1'; } catch (_) {}
      if (seen) return;

      const cards = Array.from(grid.children);
      cards.forEach((li, i) => {
        li.style.setProperty('--stagger-delay', (i * 30) + 'ms');
      });
      grid.classList.add('stagger');
      try { sessionStorage.setItem('unisomnia.catalog.seen', '1'); } catch (_) {}
    })();
  </script>
</Layout>
