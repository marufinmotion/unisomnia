---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import Layout from '../../../layouts/Layout.astro';
import { getStrings, TELEGRAM_BOT_URL } from '../../../i18n';
import type { Lang } from '../../../i18n';
import { getCollection, render } from 'astro:content';

// Build-time per-country image maps (hero + inline-2 slot).
const heroImages = import.meta.glob<{ default: ImageMetadata }>(
  '../../../assets/countries/*/hero.jpg',
  { eager: true },
);
const inlineImages = import.meta.glob<{ default: ImageMetadata }>(
  '../../../assets/countries/*/inline.jpg',
  { eager: true },
);
type CountryCredits = {
  hero: { photographer: string; unsplashId: string; url: string };
  inline: { photographer: string; unsplashId: string; url: string };
};
const countryCredits = import.meta.glob<{ default: CountryCredits }>(
  '../../../assets/countries/*/credits.json',
  { eager: true },
);

// Shared image pools for inline-3 (street, between Cost/Safety) and
// inline-4 (campus, between Visa/Links). Rotated by country index.
const streetImages = import.meta.glob<{ default: ImageMetadata }>(
  '../../../assets/shared/street-*.jpg',
  { eager: true },
);
const campusImages = import.meta.glob<{ default: ImageMetadata }>(
  '../../../assets/shared/campus-*.jpg',
  { eager: true },
);
type SharedCreditEntry = { photographer: string; unsplashId: string; url: string };
type SharedCredits = Record<string, SharedCreditEntry>;
const sharedCredits = (
  await import('../../../assets/shared/credits.json')
).default as SharedCredits;

const streetKeys = Object.keys(streetImages).sort();
const campusKeys = Object.keys(campusImages).sort();

function pickShared(
  pool: Record<string, { default: ImageMetadata }>,
  keys: string[],
  index: number,
): { img: ImageMetadata; credit: SharedCreditEntry } | null {
  if (!keys.length) return null;
  const key = keys[index % keys.length];
  const img = pool[key]?.default;
  // Extract "street-haberdoedas" from ".../shared/street-haberdoedas.jpg"
  const base = key.split('/').pop()?.replace(/\.jpg$/, '') ?? '';
  const credit = sharedCredits[base];
  return img && credit ? { img, credit } : null;
}

export async function getStaticPaths() {
  const all = await getCollection('countries');
  return all.map((entry) => {
    const [lang, slug] = entry.id.split('/');
    return {
      params: { lang, country: slug },
      props: { entry },
    };
  });
}

const { entry } = Astro.props;
const lang = Astro.params.lang as Lang;
const t = getStrings(lang);
const { Content } = await render(entry);

const sectionMap = t.country.sections;
const sectionOrder: (keyof typeof sectionMap)[] = [
  'overview', 'universities', 'process', 'requirements',
  'scholarships', 'cost', 'safety', 'visa', 'links',
];

const slug = entry.data.slug;
const heroKey = `../../../assets/countries/${slug}/hero.jpg`;
const inlineKey = `../../../assets/countries/${slug}/inline.jpg`;
const creditsKey = `../../../assets/countries/${slug}/credits.json`;

const heroImg = heroImages[heroKey]?.default;
const inlineImg2 = inlineImages[inlineKey]?.default;
const credits = countryCredits[creditsKey]?.default;

// Rotate shared images deterministically by country order so the same
// country always gets the same shared pictures.
const orderIdx = (entry.data.order ?? 1) - 1;
const slot3 = pickShared(streetImages, streetKeys, orderIdx);
const slot4 = pickShared(campusImages, campusKeys, orderIdx);

const heroAlt = t.country.heroAlt.replace('{country}', entry.data.name);
const photoCaption = (name: string) =>
  t.country.photoCaption.replace('{photographer}', name);
---

<Layout lang={lang} title={entry.data.name}>
  <article class="page-container py-12 md:py-16">
    <a
      href={`/${lang}/apply`}
      class="inline-block mb-8 text-sm text-[color:var(--color-ink-muted)] hover:text-[color:var(--color-red)] transition-colors"
    >
      {t.country.back}
    </a>

    {heroImg && (
      <figure class="country-hero mb-10">
        <div class="country-hero-frame">
          <Image
            src={heroImg}
            alt={heroAlt}
            widths={[480, 720, 960, 1280, 1600]}
            sizes="(min-width: 1280px) 1216px, 100vw"
            format="webp"
            quality={75}
            class="country-hero-img"
            loading="eager"
            fetchpriority="high"
          />
        </div>
        {credits && (
          <figcaption class="country-hero-caption">
            <a
              href={credits.hero.url}
              target="_blank"
              rel="noopener noreferrer"
              class="hover:text-[color:var(--color-red)] transition-colors"
            >{photoCaption(credits.hero.photographer)}</a>
          </figcaption>
        )}
      </figure>
    )}

    {/* C.1: removed the КАТАЛОГ eyebrow. Page flows hero → name directly. */}
    <header class="mb-16 flex flex-wrap items-end gap-6 border-b border-[color:var(--color-rule)] pb-12">
      <span class="text-7xl leading-none" aria-hidden="true">{entry.data.flag}</span>
      <div>
        <h1
          style="font-family: var(--font-display); font-size: clamp(2.5rem, 6vw, 4rem); font-weight: 600; line-height: 1.04; letter-spacing: -0.02em;"
        >{entry.data.name}</h1>
      </div>
    </header>

    <div class="grid grid-cols-1 gap-x-16 gap-y-12 lg:grid-cols-[minmax(0,1fr)_18rem]">
      <div class="prose-column">
        {/* Mobile: collapsible on-this-page nav */}
        <nav aria-label={t.country.onThisPage} class="mb-12 lg:hidden">
          <details class="border-y border-[color:var(--color-rule)] py-3">
            <summary class="cursor-pointer text-sm font-medium">{t.country.onThisPage}</summary>
            <ul class="mt-4 flex flex-col gap-2 text-sm">
              {sectionOrder.map((key, i) => (
                <li>
                  <a
                    href={`#${key}`}
                    data-section-link
                    class="flex items-baseline gap-3 text-[color:var(--color-ink-muted)] hover:text-[color:var(--color-red)] transition-colors"
                  >
                    <span class="text-xs tabular-nums text-[color:var(--color-rule)]">
                      {String(i + 1).padStart(2, '0')}
                    </span>
                    <span>{sectionMap[key]}</span>
                  </a>
                </li>
              ))}
            </ul>
          </details>
        </nav>

        <div class="country-prose">
          <Content />
        </div>

        {/* Three inline figures, SSR'd at end of prose and relocated by
            client JS into the spec's slots:
              [data-inline-figure="2"] → before #requirements
              [data-inline-figure="3"] → before #safety
              [data-inline-figure="4"] → before #links             */}
        {inlineImg2 && (
          <figure data-inline-figure="2" class="country-inline reveal" hidden>
            <div class="country-inline-frame">
              <Image
                src={inlineImg2}
                alt={t.country.inlineAlt}
                widths={[480, 720, 960, 1280]}
                sizes="(min-width: 1280px) 720px, 100vw"
                format="webp"
                quality={75}
                class="country-inline-img"
                loading="lazy"
                decoding="async"
              />
            </div>
            {credits && (
              <figcaption class="country-inline-caption">
                <a
                  href={credits.inline.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="hover:text-[color:var(--color-red)] transition-colors"
                >{photoCaption(credits.inline.photographer)}</a>
              </figcaption>
            )}
          </figure>
        )}

        {slot3 && (
          <figure data-inline-figure="3" class="country-inline reveal" hidden>
            <div class="country-inline-frame">
              <Image
                src={slot3.img}
                alt={t.country.inlineAlt}
                widths={[480, 720, 960, 1280]}
                sizes="(min-width: 1280px) 720px, 100vw"
                format="webp"
                quality={75}
                class="country-inline-img"
                loading="lazy"
                decoding="async"
              />
            </div>
            <figcaption class="country-inline-caption">
              <a
                href={slot3.credit.url}
                target="_blank"
                rel="noopener noreferrer"
                class="hover:text-[color:var(--color-red)] transition-colors"
              >{photoCaption(slot3.credit.photographer)}</a>
            </figcaption>
          </figure>
        )}

        {slot4 && (
          <figure data-inline-figure="4" class="country-inline reveal" hidden>
            <div class="country-inline-frame">
              <Image
                src={slot4.img}
                alt={t.country.inlineAlt}
                widths={[480, 720, 960, 1280]}
                sizes="(min-width: 1280px) 720px, 100vw"
                format="webp"
                quality={75}
                class="country-inline-img"
                loading="lazy"
                decoding="async"
              />
            </div>
            <figcaption class="country-inline-caption">
              <a
                href={slot4.credit.url}
                target="_blank"
                rel="noopener noreferrer"
                class="hover:text-[color:var(--color-red)] transition-colors"
              >{photoCaption(slot4.credit.photographer)}</a>
            </figcaption>
          </figure>
        )}

        <p class="mt-16 text-xs italic text-[color:var(--color-ink-muted)]">
          {t.country.timestamp}
        </p>

        <div class="mt-12 border-t border-[color:var(--color-rule)] pt-12">
          <span aria-hidden="true" class="block w-[60px] h-[1.5px] bg-[color:var(--color-red)] mb-5"></span>
          <p
            class="mb-3"
            style="font-family: var(--font-display); font-size: 0.8125rem; text-transform: uppercase; letter-spacing: 0.18em; color: var(--color-red); font-weight: 500;"
          >
            {t.country.botCta.title}
          </p>
          <p class="mb-7 text-lg leading-relaxed">{t.country.botCta.body}</p>
          <a
            href={TELEGRAM_BOT_URL}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 border border-[color:var(--color-ink)] px-7 py-3 text-sm font-medium hover:border-[color:var(--color-red)] hover:text-[color:var(--color-red)] transition-colors"
          >
            <span>{t.country.botCta.button}</span>
            <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>

      <aside class="lg:sticky lg:top-8 lg:self-start">
        {/* Quick Facts */}
        <div class="border-y border-[color:var(--color-rule)] py-6">
          <p
            class="mb-5"
            style="font-family: var(--font-display); font-size: 0.8125rem; text-transform: uppercase; letter-spacing: 0.18em; color: var(--color-red); font-weight: 500;"
          >
            {t.country.quickFacts.title}
          </p>
          <dl class="space-y-4 text-sm">
            <div class="flex justify-between gap-4">
              <dt class="text-[color:var(--color-ink-muted)]">{t.country.quickFacts.capital}</dt>
              <dd class="text-right">{entry.data.capital}</dd>
            </div>
            <div class="flex justify-between gap-4">
              <dt class="text-[color:var(--color-ink-muted)]">{t.country.quickFacts.languages}</dt>
              <dd class="text-right">{entry.data.languages.join(', ')}</dd>
            </div>
            <div class="flex justify-between gap-4">
              <dt class="text-[color:var(--color-ink-muted)]">{t.country.quickFacts.currency}</dt>
              <dd class="text-right tabular-nums">{entry.data.currency}</dd>
            </div>
            <div class="flex justify-between gap-4">
              <dt class="text-[color:var(--color-ink-muted)]">{t.country.quickFacts.monthly}</dt>
              <dd class="text-right tabular-nums">${entry.data.monthlyCostUSD}{t.country.quickFacts.usdSuffix}</dd>
            </div>
          </dl>
        </div>

        {/* Desktop on-this-page nav */}
        <nav aria-label={t.country.onThisPage} class="mt-10 hidden lg:block">
          <p
            class="mb-4"
            style="font-family: var(--font-display); font-size: 0.8125rem; text-transform: uppercase; letter-spacing: 0.18em; color: var(--color-red); font-weight: 500;"
          >
            {t.country.onThisPage}
          </p>
          <ul class="flex flex-col gap-2.5 text-sm">
            {sectionOrder.map((key, i) => (
              <li>
                <a
                  href={`#${key}`}
                  data-section-link
                  class="group flex items-baseline gap-3 text-[color:var(--color-ink-muted)] hover:text-[color:var(--color-red)] transition-colors"
                >
                  <span class="tabular-nums text-xs text-[color:var(--color-rule)] group-hover:text-[color:var(--color-red)] transition-colors">
                    {String(i + 1).padStart(2, '0')}
                  </span>
                  <span>{sectionMap[key]}</span>
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </aside>
    </div>
  </article>

  <script is:inline>
    // Relocate the three inline figures into the slots defined by the spec.
    // SSR'd order is "after all content"; we move each one above its target H2's
    // preceding .section-marker.
    (function () {
      const placements = [
        { slotAttr: '2', targetId: 'requirements' },
        { slotAttr: '3', targetId: 'safety' },
        { slotAttr: '4', targetId: 'links' },
      ];
      for (const { slotAttr, targetId } of placements) {
        const fig = document.querySelector('[data-inline-figure="' + slotAttr + '"]');
        if (!fig) continue;
        const target = document.getElementById(targetId);
        if (!target) {
          fig.hidden = false;
          continue;
        }
        const marker = target.previousElementSibling;
        const before = marker && marker.classList.contains('section-marker') ? marker : target;
        before.parentNode.insertBefore(fig, before);
        fig.hidden = false;
      }
    })();

    // Scroll-triggered fade-in: section markers + inline figures.
    (function () {
      const reduced =
        window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const targets = document.querySelectorAll(
        '[data-section-reveal], [data-inline-figure]'
      );
      if (!targets.length) return;
      if (reduced || !('IntersectionObserver' in window)) {
        targets.forEach((el) => el.classList.add('is-visible'));
        return;
      }
      const io = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (e.isIntersecting) {
              e.target.classList.add('is-visible');
              io.unobserve(e.target);
            }
          }
        },
        { threshold: 0.2, rootMargin: '0px 0px -10% 0px' },
      );
      targets.forEach((el) => io.observe(el));
    })();

    // C.2: JS smooth scroll on on-page section nav clicks.
    // 1000ms, easeInOutCubic. Reduced-motion users get instant jumps.
    (function () {
      const reduced =
        window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const SCROLL_MARGIN = 96; // matches scroll-margin-top: 6rem
      function easeInOutCubic(t) {
        return t < 0.5 ? 4 * t * t * t : 1 - Math.pow(-2 * t + 2, 3) / 2;
      }
      function scrollToTarget(targetY, duration) {
        const startY = window.scrollY || window.pageYOffset;
        const distance = targetY - startY;
        const start = performance.now();
        function tick(now) {
          const elapsed = now - start;
          const t = Math.min(1, elapsed / duration);
          window.scrollTo(0, startY + distance * easeInOutCubic(t));
          if (t < 1) requestAnimationFrame(tick);
        }
        requestAnimationFrame(tick);
      }
      document.addEventListener('click', (e) => {
        const t = e.target;
        if (!(t instanceof Element)) return;
        const a = t.closest('a[data-section-link]');
        if (!a) return;
        const href = a.getAttribute('href') || '';
        if (!href.startsWith('#')) return;
        const id = href.slice(1);
        const target = document.getElementById(id);
        if (!target) return;
        e.preventDefault();
        const rect = target.getBoundingClientRect();
        const targetY = (window.scrollY || window.pageYOffset) + rect.top - SCROLL_MARGIN;
        if (reduced) {
          window.scrollTo(0, targetY);
        } else {
          scrollToTarget(targetY, 1000);
        }
        // Update URL hash without re-jumping.
        history.replaceState(null, '', '#' + id);
      });
    })();
  </script>
</Layout>
