---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SearchModal from '../components/SearchModal.astro';
import type { Lang } from '../i18n';
import { getStrings } from '../i18n';

interface Props {
  lang: Lang;
  title: string;
  description?: string;
}

const { lang, title, description } = Astro.props;
const t = getStrings(lang);
const fullTitle = title === t.siteName ? title : `${title} — ${t.siteName}`;
const desc = description ?? t.tagline;
---

<!doctype html>
<html lang={t.htmlLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>
    <meta name="description" content={desc} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;0,9..144,700;1,9..144,400;1,9..144,500&family=Inter:wght@400;500;600&family=Lora:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&display=swap"
    />
  </head>
  <body class="flex min-h-screen flex-col">
    <div id="nav-progress" aria-hidden="true"></div>
    <Header lang={lang} />
    <main class="flex-1">
      <slot />
    </main>
    <Footer lang={lang} />
    <SearchModal lang={lang} />
    <script is:inline>
      // Persist language preference whenever a user lands on /ru/ or /tg/
      (function () {
        try {
          const path = location.pathname;
          if (path.startsWith('/ru/') || path === '/ru') {
            localStorage.setItem('unisomnia.lang', 'ru');
          } else if (path.startsWith('/tg/') || path === '/tg') {
            localStorage.setItem('unisomnia.lang', 'tg');
          }
        } catch (_) {}
      })();

      // Top progress bar — fires on internal link clicks for same-origin
      // navigation. Eases from 0% to ~70% with simulated work, jumps to
      // 100% on actual load (pageshow). Respects reduced motion.
      (function () {
        const bar = document.getElementById('nav-progress');
        if (!bar) return;
        const reduced =
          window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        let timer = null;
        let progress = 0;

        function start() {
          progress = 0;
          bar.style.width = '0%';
          bar.classList.remove('is-done');
          bar.classList.add('is-active');
          // Simulate work: ease toward 70% over ~700ms in 3 nudges.
          if (reduced) {
            bar.style.width = '70%';
            return;
          }
          if (timer) clearTimeout(timer);
          const nudges = [
            [60,   30],
            [240,  55],
            [550,  70],
          ];
          nudges.forEach(([delay, pct]) => {
            setTimeout(() => {
              if (!bar.classList.contains('is-done')) {
                progress = pct;
                bar.style.width = pct + '%';
              }
            }, delay);
          });
        }
        function finish() {
          bar.classList.remove('is-active');
          bar.classList.add('is-done');
          setTimeout(() => {
            bar.classList.remove('is-done');
            bar.style.width = '0%';
          }, 500);
        }

        document.addEventListener('click', (e) => {
          const t = e.target;
          if (!(t instanceof Element)) return;
          const a = t.closest('a[href]');
          if (!a) return;
          const href = a.getAttribute('href') || '';
          // Skip anchors-only, externals, mailto/tel, new-window, downloads.
          if (
            href.startsWith('#') ||
            href.startsWith('mailto:') ||
            href.startsWith('tel:') ||
            a.target === '_blank' ||
            a.hasAttribute('download') ||
            (a.host && a.host !== location.host)
          ) return;
          start();
        });
        // pageshow fires both on initial load and bfcache restore.
        window.addEventListener('pageshow', finish);
      })();

      // Mark image frames as loaded so the shimmer fades on initial paint.
      (function () {
        const frames = document.querySelectorAll(
          '.country-hero-frame, .country-inline-frame, .landing-figure-frame'
        );
        frames.forEach((frame) => {
          const img = frame.querySelector('img');
          if (!img) return;
          if (img.complete && img.naturalWidth > 0) {
            frame.classList.add('is-loaded');
            return;
          }
          img.addEventListener('load', () => frame.classList.add('is-loaded'), { once: true });
          img.addEventListener('error', () => frame.classList.add('is-loaded'), { once: true });
        });
      })();
    </script>
  </body>
</html>
